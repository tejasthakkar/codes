import networkx as nx
import matplotlib.pyplot as plt

G=nx.DiGraph()

G.add_nodes_from(range(4))
l=[[0,1,0,1],[0,0,0,1],[1,0,0,0],[1,0,1,0]]

for i in range(4):
    for j in range(4):
        if l[i][j]==1:
            G.add_edge(i,j)

nx.draw_networkx(G,node_size=850,node_color='red',edge_color='blue',width=3)
plt.show()
